@using P2PReview.Application.Interfaces
@using P2PReview.Application.Notifications
@using P2PReview.Web.Components.Icons
@using P2PReview.Web.Services
@using P2PReview.Web.State

@inherits LayoutComponentBase

@inject NavigationManager Navigation
@inject UserContext UserContext
@inject AvatarUrlProvider AvatarUrlProvider
@inject INotificationsService NotificationsService

@implements IDisposable

<PageTitle>P2P Review</PageTitle>

<div class="app">

    <header class="topbar">

        <a class="logo" href="/">
            P2P Review
        </a>

        <nav></nav>

        @if (UserContext.Profile != null)
        {
            <div class="topbar-actions">

                <div class="notifications-trigger"
                     @onclick="ToggleNotifications">

                    <i class="fa-regular fa-bell"></i>

                    @if (UserContext.Notifications.Any(x => x.IsNew))
                    {
                        <span class="badge">
                            @Math.Clamp(
                                UserContext.Notifications.Count(x => x.IsNew),
                                0,
                                9)
                        </span>
                    }

                </div>

                <a href="/profile" class="score-link">
                    <i class="fa-solid fa-bolt"></i>
                    <span>@(UserContext.Profile?.QualityScore ?? 0)</span>
                </a>

                <a href="/profile" class="profile-link">
                    <img class="avatar-topbar"
                         src="@AvatarUrlProvider.GetAvatarUrl(UserContext.Profile?.AvatarId)" />
                </a>

            </div>
        }
        else
        {
            <a class="login" href="/login">
                Войти
            </a>
        }

    </header>

    <main class="content">
        @Body
    </main>

</div>

@if (isNotificationsOpen)
{
    <div class="notifications-overlay" @onclick="CloseNotifications">

        <div class="notifications-modal"
             @onclick:stopPropagation="true">

            <div class="notifications-header">
                <h3>Уведомления</h3>

                <button class="close-btn"
                        @onclick="CloseNotifications">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>

            <div class="notifications-list">

                @if (UserContext.Notifications.Count == 0)
                {
                    <div class="empty-notifications">
                        Пусто :(
                    </div>
                }
                else
                {
                    @foreach (var notification in UserContext.Notifications.OrderByDescending(x => x.CreatedAt))
                    {
                        var not = notification;
                        
                        <button @onclick="async () => await OpenNotification(not)"
                           class="notification-item">

                            <div class="notification-content">

                                <div class="notification-title">
                                    @notification.Title
                                </div>

                                <div class="notification-date">
                                    @notification.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                                </div>

                            </div>

                        </button>
                    }
                }

            </div>

        </div>

    </div>
}


@code {
    private bool isNotificationsOpen;

    private void ToggleNotifications()
    {
        isNotificationsOpen = !isNotificationsOpen;
    }

    private void CloseNotifications()
    {
        isNotificationsOpen = false;
    }

    private async Task OpenNotification(NotificationDto notificationDto)
    {
        Navigation.NavigateTo(notificationDto.Url, forceLoad: true);

        await NotificationsService.ViewNotificationAsync(notificationDto.Id);
    }


    protected override async Task OnInitializedAsync()
    {
        UserContext.OnChange -= HandleUserChanged;
        UserContext.OnChange += HandleUserChanged;

        await UserContext.InitializeAsync();
    }

    private void HandleUserChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        UserContext.OnChange -= HandleUserChanged;
    }
}
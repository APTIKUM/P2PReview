@page "/review/request/create"

@using Microsoft.AspNetCore.Authorization
@using P2PReview.Application.Extensions
@using P2PReview.Application.Files
@using P2PReview.Application.Interfaces
@using P2PReview.Application.ReviewRequests
@using P2PReview.Domain.Enums
@using P2PReview.Domain.ConstantsImLazy
@using P2PReview.Web.Components.Shared

@rendermode InteractiveServer
@attribute [Authorize]

@inject IJSRuntime JS
@inject NavigationManager Nav
@inject IFileService FileService
@inject IReviewRequestService ReviewRequestService

<div class="review-request-create-page">

    <!-- HEADER -->
    <div class="page-header">
        <h1>Новый запрос на ревью</h1>
    </div>


    <!-- PROJECT INFO -->
    <div class="card">

        <div class="section-title">
            <i class="fa-regular fa-file-lines"></i>
            <span>Информация о проекте</span>
        </div>

        <div class="form-group">
            <label>Название</label>
            <input type="text"
                   maxlength="1000"
                   placeholder="Введите название"
                   @bind="model.Name" />

            @if (!string.IsNullOrWhiteSpace(errorName)
            && string.IsNullOrWhiteSpace(model.Name))
            {
                <div class="validation-error">
                    @errorName
                </div>
            }

        </div>

        <div class="form-group">
            <label>Описание</label>
            <textarea rows="4"
                      maxlength="5000"
                      placeholder="Краткое описание проекта"
                      @bind="model.Description"></textarea>
        </div>

        <div class="form-group">

            <label>
                Стек технологий
            </label>

            <div class="tags-picker">

                @foreach (var tag in model.Tags)
                {
                    <div class="selected-tag">

                        <span>@tag</span>

                        <button type="button"
                                @onclick="() => RemoveTag(tag)">
                            ✕
                        </button>

                    </div>
                }

                @if (model.Tags.Count < 5)
                {
                    <input class="tag-input"
                           placeholder="Начните вводить..."
                           @bind="tagInput"
                           @bind:event="oninput" />
                }

            </div>

            @if (!string.IsNullOrWhiteSpace(tagInput))
            {
                <div class="tags-suggestions">

                    @foreach (var tag in Suggestions)
                    {
                        <button type="button"
                                class="suggestion-item"
                                @onclick="() => AddTag(tag)">
                            @tag
                        </button>
                    }

                </div>
            }

        </div>
    </div>

    <!-- UPLOAD -->
    <div class="card">

        <div class="section-title">
            <i class="fa-solid fa-upload"></i>
            <span>Загрузка кода</span>
        </div>

        <div class="select-tabs">

            <button class="tab @(CurUploadMode == UploadMode.Manual ? "active" : "")"
                    @onclick="() => SetUploadCodeMode(UploadMode.Manual)">
                Ручная загрузка
            </button>

            <button class="tab @(CurUploadMode == UploadMode.Paste ? "active" : "")"
                    @onclick="() => SetUploadCodeMode(UploadMode.Paste)">
                Вставка кода
            </button>

            <button class="tab @(CurUploadMode == UploadMode.Git ? "active" : "")"
                    @onclick="() => SetUploadCodeMode(UploadMode.Git)">
                Git интеграция
            </button>

        </div>

        @if (CurUploadMode == UploadMode.Manual)
        {
            <div class="upload-box"
                 @ondragover:preventDefault="true"
                 @ondrop="HandleDrop">

                <i class="fa-solid fa-cloud-arrow-up upload-icon"></i>

                <div class="upload-text">
                    Перетащите файлы сюда или выберите с компьютера
                </div>

                <InputFile OnChange="OnFilesSelected"
                           multiple
                           class="file-input" />

            </div>

            @if (uploadedFiles.Any())
            {
                <div class="file-list">
                    @foreach (var file in uploadedFiles)
                    {
                        <div class="file-item">

                            <div class="file-header">
                                @file.Name
                                <button class="remove-btn"
                                        @onclick="() => RemoveFile(file)">
                                    ✕
                                </button>
                            </div>
                        </div>
                    }

                </div>
            }
        }

        @if (CurUploadMode == UploadMode.Paste)
        {
            <div class="form-group">

                <label>Язык</label>

                <select @bind="pasteCodeLanguage">

                    @foreach (var language in Enum.GetValues<CodeLanguage>())
                    {
                        <option value="@language">
                            @CodeLanguageExtensions.ToDisplayName(language)
                        </option>
                    }
                </select>

            </div>

            <div class="editor-panel" style="height : 600px;">
                <MonacoEditor @bind-Value="pasteCodeContent"
                              CodeLanguage="@pasteCodeLanguage"/>
            </div>
        }

        @if (CurUploadMode == UploadMode.Git)
        {
            <div class="form-group">
                <label class="not-implemented">Git URL</label>
                <input class="not-implemented" type="text" placeholder="https://github.com/..." />
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(errorUploadCode))
        {
            <div class="validation-error">
                @errorUploadCode
            </div>
        }

    </div>

    <!-- REVIEW SETTINGS -->
    <div class="card">

        <div class="section-title">
            <i class="fa-solid fa-gear"></i>
            <span>Настройки ревью</span>
        </div>

        <div class="form-group">
            <label>Количество ревьюеров</label>

            <div class="select-tabs ">

                <button class="tab digit @(model.ReviewersCount == 1 ? "active" : "")"
                        @onclick="() => model.ReviewersCount = 1">
                    1
                </button>

                <button class="tab digit @(model.ReviewersCount == 2 ? "active" : "")"
                        @onclick="() => model.ReviewersCount = 2">
                    2
                </button>

                <button class="tab digit @(model.ReviewersCount == 3 ? "active" : "")"
                        @onclick="() => model.ReviewersCount = 3">
                    3
                </button>

                <button class="tab digit @(model.ReviewersCount == 4 ? "active" : "")"
                        @onclick="() => model.ReviewersCount = 4">
                    4
                </button>

            </div>
        </div>

        <div class="form-group">
            <label>Сложность</label>

            <div class="select-tabs">

                <button class="tab easy @(model.Difficulty == 0 ? "active" : "")"
                        @onclick="() => model.Difficulty = 0">
                    легко
                </button>

                <button class="tab norm @(model.Difficulty == 1 ? "active" : "")"
                        @onclick="() => model.Difficulty = 1">
                    нормально
                </button>

                <button class="tab hard @(model.Difficulty == 2 ? "active" : "")"
                        @onclick="() => model.Difficulty = 2">
                    сложно
                </button>

            </div>
        </div>

        <!-- DEADLINE TOGGLE -->
        <div class="form-group">
            <label class="toggle-label">
                <span class="label-text">Дедлайн</span>

                <label class="switch">
                    <input type="checkbox"
                           @bind="ToggleDeadline" />
                    <span class="slider"></span>
                </label>
            </label>

            <!-- DEADLINE DATE -->
            @if (ToggleDeadline)
            {
                <input type="date"
                       @bind="model.Deadline" />

                <small class="hint">
                    После дедлайна ревью автоматически закрывается
                </small>
            }

            @if (!string.IsNullOrWhiteSpace(errorDeadline))
            {
                <div class="validation-error">
                    @errorDeadline
                </div>
            }

        </div>


        <div class="form-group">
            <label class="checkbox-label toggle-label">
                <span class="label-text">
                    Автоматически назначить ревьюера
                </span>

                <label class="switch">
                    <input type="checkbox"
                           @bind="model.IsAutoAssignReviewer" />
                    <span class="slider"></span>
                </label>
            </label>

            <small class="hint">
                Система подберет подходящего ревьюера
            </small>
        </div>

        <!-- EDUCATIONAL TOGGLE -->
        <div class="form-group">
            <label class="checkbox-label toggle-label">
                <span class="label-text">
                    Разрешаю использовать проект в образовательной базе ревью
                </span>

                <label class="switch">
                    <input type="checkbox"
                           @bind="model.AllowEducationalUse" />
                    <span class="slider"></span>
                </label>
            </label>

            <small class="hint">
                Проект может быть опубликован анонимно и использован для обучения ревьюеров
            </small>
        </div>
    </div>

    <!-- ACTIONS -->
    <div class="actions">

        <button type="button" class="btn-save" @onclick="Create">
            Создать
        </button>


        <button type="button"
                class="btn-cancel"
                @onclick="Cancel">
            Отмена
        </button>


    </div>

</div>

@code {
    private CreateReviewRequestDto model = new();

    private UploadMode CurUploadMode = UploadMode.Manual;

    private CodeLanguage pasteCodeLanguage = 0;

    private string pasteCodeContent = "";

    public enum UploadMode
    {
        Manual,
        Paste,
        Git
    }

    private bool toggleDeadline = false;

    public bool ToggleDeadline
    {
        get => toggleDeadline;
        set
        {
            toggleDeadline = value;
            model.Deadline = null;
        }
    }

    private List<ReadedCodeFileDto> uploadedFiles = new();

    private string? errorName = null;
    private string? errorUploadCode = null;
    private string? errorDeadline = null;

    private async Task OnFilesSelected(InputFileChangeEventArgs e)
    {
        foreach (var file in e.GetMultipleFiles())
        {
            AddFile(await FileService.ReadCodeFileAsync(file));
        }
    }

    private void HandleDrop(DragEventArgs e)
    {
        // Blazor не даёт FileList напрямую,
        // поэтому используем InputFile как основной канал

        // в душе не чаю шо это значит , так ии сказала , а мне как-бы пофиг , я в фронте не волоку особо
    }

    private void AddFile(ReadedCodeFileDto file)
    {
        if (!uploadedFiles.Any(f => f.Name == file.Name))
        {
            uploadedFiles.Add(file);
        }
    }

    private void RemoveFile(ReadedCodeFileDto file)
    {
        uploadedFiles.Remove(file);
    }

    private void SetUploadCodeMode(UploadMode mode)
    {
        CurUploadMode = mode;

        errorUploadCode = null;
        uploadedFiles.Clear();
        pasteCodeLanguage = 0;
        pasteCodeContent = "";
    }

    private void Cancel()
    {
        Nav.NavigateTo("/profile");
    }

    private bool ValidateModel()
    {
        var success = true;

        errorName = null;
        errorUploadCode = null;
        errorDeadline = null;

        if (string.IsNullOrWhiteSpace(model.Name))
        {
            errorName = "Обязательно для заполнения";
            success = false;
        }


        if (CurUploadMode == UploadMode.Manual)
        {
            if (uploadedFiles.Count == 0)
            {
                errorUploadCode = "Файлы не загружены";
                success = false;
            }
        }
        else if (CurUploadMode == UploadMode.Paste)
        {
            if (string.IsNullOrWhiteSpace(pasteCodeContent))
            {
                errorUploadCode = "Пустой файл";
                success = false;
            }
        }
        else
        {
            errorUploadCode = "Git интеграция находится в разработке :) Используйте другой способ загрузки кода";
            success = false;
        }


        if (model.Deadline != null && model.Deadline < DateTime.Today)
        {
            errorDeadline = "Дедлайн уже прошел";
            success = false;
        }

        return success;
    }

    private void StupidTechStack()
    {
        try
        {
            model.TechStack = CodeLanguageExtensions.ToDisplayName(
            CodeLanguageExtensions.FromFileName(uploadedFiles.First().Name));
        }
        catch
        {

        }
    }

    private async Task Create()
    {
        if (!ValidateModel())
        {
            return;
        }

        if (CurUploadMode == UploadMode.Paste)
        {
            AddFile(new ReadedCodeFileDto()
            {
                Name = $"main{CodeLanguageExtensions.GetExtension(pasteCodeLanguage)}",
                Content = pasteCodeContent
            });
        }

        StupidTechStack();

        var id = await ReviewRequestService.CreateReviewRequestAsync(model, uploadedFiles);

        Nav.NavigateTo($"/review/request/{id}", true);
    }


    private string tagInput = "";

    private IEnumerable<string> Suggestions =>
        ReviewTags.All
            .Where(x =>
                !model.Tags.Contains(x) &&
                x.Contains(tagInput, StringComparison.OrdinalIgnoreCase))
            .Take(8);

    private void AddTag(string tag)
    {
        if (model.Tags.Count >= 5)
            return;

        if (model.Tags.Contains(tag))
            return;

        model.Tags.Add(tag);

        tagInput = "";
    }

    private void RemoveTag(string tag)
    {
        model.Tags.Remove(tag);
    }
}
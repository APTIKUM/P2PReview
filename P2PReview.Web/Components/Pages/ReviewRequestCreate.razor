@page "/review/request/create"

@using Microsoft.AspNetCore.Authorization
@using P2PReview.Application.Files
@using P2PReview.Application.Interfaces
@using P2PReview.Application.ReviewRequests
@using P2PReview.Domain.Enums
@using P2PReview.Web.Components.Shared
@using Microsoft.AspNetCore.Components.Forms
@using P2PReview.Web.Extensions

@rendermode InteractiveServer
@attribute [Authorize]

@inject IJSRuntime JS
@inject NavigationManager Nav
@inject IFileService FileService

<div class="review-request-create-page">

    <!-- HEADER -->
    <div class="page-header">
        <h1>Новый запрос на ревью</h1>
    </div>

    <!-- PROJECT INFO -->
    <div class="card">

        <div class="section-title">
            <i class="fa-regular fa-file-lines"></i>
            <span>Информация о проекте</span>
        </div>

        <div class="form-group">
            <label>Название</label>
            <input type="text"
                   placeholder="Введите название"
                   @bind="Model.Name" />
        </div>

        <div class="form-group">
            <label>Описание</label>
            <textarea rows="4"
                      placeholder="Краткое описание проекта"
                      @bind="Model.Description"></textarea>
        </div>

        <div class="form-group">
            <label class="not-implemented">Стек технологий</label>
        </div>

       

    </div>

    <!-- UPLOAD -->
    <div class="card">

        <div class="section-title">
            <i class="fa-solid fa-upload"></i>
            <span>Загрузка кода</span>
        </div>

        <div class="select-tabs">

            <button class="tab @(CurUploadMode == UploadMode.Manual ? "active" : "")"
                    @onclick="() => SetUploadCodeMode(UploadMode.Manual)">
                Ручная загрузка
            </button>

            <button class="tab @(CurUploadMode == UploadMode.Paste ? "active" : "")"
                    @onclick="() => SetUploadCodeMode(UploadMode.Paste)">
                Вставка кода
            </button>

            <button class="tab @(CurUploadMode == UploadMode.Git ? "active" : "")"
                    @onclick="() => SetUploadCodeMode(UploadMode.Git)">
                Git интеграция
            </button>

        </div>

        @if (CurUploadMode == UploadMode.Manual)
        {
            <div class="upload-box"
                 @ondragover:preventDefault="true"
                 @ondrop="HandleDrop">

                <i class="fa-solid fa-cloud-arrow-up upload-icon"></i>

                <div class="upload-text">
                    Перетащите файлы сюда или выберите с компьютера
                </div>

                <InputFile OnChange="OnFilesSelected"
                           multiple
                           class="file-input" />

            </div>

            @if (Files.Any())
            {
                <div class="file-list">
                    @foreach (var file in Files)
                    {
                        <div class="file-item">

                            <div class="file-header">
                                @file.Name
                                <button class="remove-btn"
                                        @onclick="() => RemoveFile(file)">
                                    ✕
                                </button>
                            </div>

                            <pre class="file-content">@file.Content</pre>

                        </div>
                    }

                </div>
            }
        }

        @if (CurUploadMode == UploadMode.Paste)
        {
            <div class="form-group">

                <label>Язык</label>

                <select @bind="pasteCodeLanguage">

                    @foreach (var language in Enum.GetValues<CodeLanguage>())
                    {
                        <option value="@language">
                            @CodeLanguageExtensions.ToDisplayName(language)
                        </option>
                    }

                </select>

            </div>

            <MonacoEditor @bind-Value="pasteCode"
                          CodeLanguage="@pasteCodeLanguage"
                          MinHeight="240px"
                          MaxHeight="700px"
                          BorderRadius="16px" />
        }

        @if (CurUploadMode == UploadMode.Git)
        {
            <div class="form-group">
                <label class="not-implemented">Git URL</label>
                <input class="not-implemented" type="text" placeholder="https://github.com/..." />
            </div>
        }

    </div>

    <!-- REVIEW SETTINGS -->
    <div class="card">

        <div class="section-title">
            <i class="fa-solid fa-gear"></i>
            <span>Настройки ревью</span>
        </div>

        <div class="form-group">
            <label>Количество ревьюеров</label>

            <div class="select-tabs">

                <button class="tab @(Model.ReviewersCount == 1 ? "active" : "")"
                        @onclick="() => Model.ReviewersCount = 1">
                    1
                </button>

                <button class="tab @(Model.ReviewersCount == 2 ? "active" : "")"
                        @onclick="() => Model.ReviewersCount = 2">
                    2
                </button>
            
                <button class="tab @(Model.ReviewersCount == 3 ? "active" : "")"
                        @onclick="() => Model.ReviewersCount = 3">
                    3
                </button>

                <button class="tab @(Model.ReviewersCount == 4 ? "active" : "")"
                        @onclick="() => Model.ReviewersCount = 4">
                    4
                </button>

            </div>
        </div>

        <div class="form-group">
            <label>Сложность</label>

            <div class="select-tabs">

                <button class="tab easy @(Model.Difficulty == 0 ? "active" : "")"
                        @onclick="() => Model.Difficulty = 0">
                    легко
                </button>

                <button class="tab norm @(Model.Difficulty == 1 ? "active" : "")"
                        @onclick="() => Model.Difficulty = 1">
                    нормально
                </button>
            
                <button class="tab hard @(Model.Difficulty == 2 ? "active" : "")"
                        @onclick="() => Model.Difficulty = 2">
                    сложно
                </button>

            </div>
        </div>

        <!-- DEADLINE TOGGLE -->
        <div class="form-group">
            <label class="toggle-label">
                <span class="label-text">Дедлайн</span>

                <label class="switch">
                    <input type="checkbox"
                           @bind="ToggleDeadline" />
                    <span class="slider"></span>
                </label>
            </label>

            <!-- DEADLINE DATE -->
            @if (ToggleDeadline)
            {
                <input type="date"
                       @bind="Model.Deadline" />

                <small class="hint">
                    После дедлайна ревью автоматически закрывается
                </small>
            }

        </div>

        <!-- EDUCATIONAL TOGGLE -->
        <div class="form-group">
            <label class="checkbox-label toggle-label">
                <span class="label-text">
                    Разрешаю использовать проект в образовательной базе ревью
                </span>

                <label class="switch">
                    <input type="checkbox"
                           @bind="Model.AllowEducationalUse" />
                    <span class="slider"></span>
                </label>
            </label>

            <small class="hint">
                Проект может быть опубликован анонимно и использован для обучения ревьюеров
            </small>
        </div>



    </div>

    <!-- ACTIONS -->
    <div class="actions">
        <button type="button"
                class="secondary-btn"
                @onclick="Cancel">
            Отмена
        </button>

        <button type="button" class="primary-btn">
            Создать
        </button>
    </div>

</div>

@code {
    private CreateReviewRequestDto Model = new();

    private UploadMode CurUploadMode = UploadMode.Manual;

    private CodeLanguage pasteCodeLanguage = 0;
    private string pasteCode = "";

    public enum UploadMode
    {
        Manual,
        Paste,
        Git
    }

    private bool toggleDeadline = false;

    public bool ToggleDeadline
    {
        get => toggleDeadline;
        set
        {
            toggleDeadline = value;
            Model.Deadline = null;
        }
    }

    private List<ReadedCodeFileDto> Files = new();

    private async Task OnFilesSelected(InputFileChangeEventArgs e)
    {
        foreach (var file in e.GetMultipleFiles())
        {
            AddFile(await FileService.ReadCodeFileAsync(file));
        }
    }

    private void HandleDrop(DragEventArgs e)
    {
        // Blazor не даёт FileList напрямую,
        // поэтому используем InputFile как основной канал

        // в душе не чаю шо это значит , так ии сказала , а мне как-бы пофиг , я в фронте не волоку особо
    }

    private void AddFile(ReadedCodeFileDto file)
    {
        if (!Files.Any(f => f.Name == file.Name))
        {
            Files.Add(file);
        }
    }

    private void RemoveFile(ReadedCodeFileDto file)
    {
        Files.Remove(file);
    }

    private void SetUploadCodeMode(UploadMode mode)
    {
        CurUploadMode = mode;

        Files.Clear();
        pasteCodeLanguage = 0;
        pasteCode = "";
    }

    private void Cancel()
    {
        Nav.NavigateTo("/profile");
    }

    private async Task Create()
    {
        //todo
    }
}
@page "/profile/{UserId:guid}"

@using Microsoft.AspNetCore.Authorization
@using P2PReview.Application.Interfaces
@using P2PReview.Application.Users
@using P2PReview.Web.Services
@using P2PReview.Application.ReviewRequests
@using P2PReview.Application.ReviewResponses
@using P2PReview.Domain.Enums

@inject NavigationManager Nav
@inject IUserService UserService
@inject IReviewRequestService ReviewRequestService
@inject IReviewResponseService ReviewResponseService
@inject AvatarUrlProvider AvatarUrlProvider

@rendermode InteractiveServer

<div class="profile-page">

    <div class="profile-card">

        @if (profile?.IsOwnProfile == true)
        {
            <a href="/logout" class="logout-icon">
                <i class="fa-solid fa-right-from-bracket"></i>
            </a>

            <a href="/settings/profile" class="edit-icon">
                <i class="fa-solid fa-pen"></i>
            </a>
        }


        <img class="profile-avatar"
             src="@AvatarUrlProvider.GetAvatarUrl(profile?.AvatarId)" />

        <h1 class="username">
            @profile?.UserName
        </h1>

        <div class="profile-score">
            <span class="score-title">Рейтинг </span>
            <span class="score-value">@profile?.QualityScore</span>
        </div>

        <div class="profile-links">

            @if (!string.IsNullOrWhiteSpace(profile?.GitHubUrl))
            {
                <a href="@profile.GitHubUrl">
                    GitHub
                </a>
            }

            @if (!string.IsNullOrWhiteSpace(profile?.GitLabUrl))
            {
                <a href="@profile.GitLabUrl">
                    GitLab
                </a>
            }

        </div>

        <div class="stats-box">

            <div class="stats-title">
                Активность ревьюера
            </div>

            <div class="metrics-grid">

                <div class="metric">
                    <div class="metric-value">
                        @(profile?.ReviewsGiven ?? 0)
                    </div>
                    <div class="metric-label">
                        Всего ревью
                    </div>
                </div>

                <div class="metric">
                    <div class="metric-value">
                        @(profile?.ReviewsEasy ?? 0)
                    </div>
                    <div class="metric-label">
                        Простые
                    </div>
                </div>

                <div class="metric">
                    <div class="metric-value">
                        @(profile?.ReviewsNormal ?? 0)
                    </div>
                    <div class="metric-label">
                        Средние
                    </div>
                </div>

                <div class="metric">
                    <div class="metric-value">
                        @(profile?.ReviewsHard ?? 0)
                    </div>
                    <div class="metric-label">
                        Сложные
                    </div>
                </div>

            </div>

        </div>

    </div>


    <!-- RIGHT PANEL -->
    <div class="profile-content">

        <div class="tabs">

            <button class="tab @(activeTab == TabsEnum.ReviewRequests ? "active" : "")"
                    @onclick="() => SetActiveTub(TabsEnum.ReviewRequests)">
                Запросы на ревью
            </button>

            <button class="tab @(activeTab == TabsEnum.ReviewResponses ? "active" : "")"
                    @onclick="() => SetActiveTub(TabsEnum.ReviewResponses)">
                Проведенные ревью
            </button>

            <button class="tab @(activeTab == TabsEnum.Friends ? "active" : "")"
                    @onclick="() => SetActiveTub(TabsEnum.Friends)">
                Друзья
            </button>

        </div>

        @if (activeTab == TabsEnum.ReviewRequests)
        {
            <div class="reviews-list">

                @if (profile?.IsOwnProfile == true && activeTab == TabsEnum.ReviewRequests)
                {
                    <a class="new-review-request-btn" href="review/request/create" data-enhance-nav="false">
                        Новый
                    </a>
                }

                @foreach (var review in reviewRequests)
                {
                    <a class="review-card" href="@($"/review/request/{review.Id}")" data-enhance-nav="false">

                        <div class="review-header">
                            <div class="review-title">
                                @review.Name
                            </div>

                            <div class="difficulty difficulty-@review.Difficulty">
                                @review.DifficultyLabel
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(review.Description))
                        {
                            <div class="review-description">
                                @(review.Description.Length <= 100 ? review.Description : review.Description.Substring(0, 100))
                            </div>
                        }

                        <div class="review-footer">

              
                            <div class="@(string.IsNullOrWhiteSpace(review.TechStack) ? "" : "review-tech")">
                                @review.TechStack
                            </div>

                            <div class="review-deadline-label">
                                @review.DeadlineLabel
                            </div>
                        </div>

                    </a>
                }

                @if (reviewRequests.Count == 0)
                {
                    <div class="empty-state">
                        Пусто :(
                    </div>
                }

            </div>
        }
        else if (activeTab == TabsEnum.ReviewResponses)
        {
            <div class="review-requests-list">

                <div class="reviews-list">

                    @foreach ((var response, var request) in reviewResponses)
                    {
                        <a class="review-card" href="@($"/review/response/{response.Id}")" data-enhance-nav="false">

                            <div class="review-header">
                                <div class="review-title">
                                    @request.Name
                                </div>

                                <div class="review-meta">

                                    <div class="difficulty difficulty-@request.Difficulty">
                                        @request.DifficultyLabel
                                    </div>

                                </div>
                            </div>


                            <div class="review-header">

                                <div class="review-description">
                                    @(request.Description)
                                </div>

                                @if (response.Status == ReviewResponseStatus.InProgress)
                                {
                                    <div class="status-banner inprogress">
                                        <i class="fa-solid fa-pen"></i>
                                        <span>В работе</span>
                                    </div>
                                }
                                else if (response.Status == ReviewResponseStatus.Submitted)
                                {
                                    <div class="status-banner submitted">
                                        <i class="fa-regular fa-clock"></i>
                                        <span>Ждет оценки</span>
                                    </div>
                                }
                                else if (response.Status == ReviewResponseStatus.Accepted)
                                {
                                    <div class="status-banner accepted">
                                        <i class="fa-solid fa-check"></i>
                                        <span>Принято</span>
                                    </div>
                                }
                                else if (response.Status == ReviewResponseStatus.Rejected)
                                {
                                    <div class="status-banner rejected">
                                        <i class="fa-solid fa-xmark"></i>
                                        <span>Отклонено</span>
                                    </div>
                                }

                            </div>

                            <div class="review-footer">

              
                                <div class="@(string.IsNullOrWhiteSpace(request.TechStack) ? "" : "review-tech")">
                                    @request.TechStack
                                </div>

                                @if (response.Status == ReviewResponseStatus.InProgress)
                                {
                                    <div class="review-deadline-label">
                                        @request.DeadlineLabel
                                    </div>
                                }
                            </div>

                        </a>
                    }

                </div>

                @if (reviewResponses.Count == 0)
                {
                    <div class="empty-state">
                        Пусто :(
                    </div>
                }

            </div>
        }
        else if (activeTab == TabsEnum.Friends)
        {
            <div class="friends-list">

                <div class="empty-state">
                    Пусто :(
                </div>

            </div>
        }
    </div>

</div>


@code {
    [Parameter] public Guid UserId { get; set; }

    private UserProfileDto? profile;
    private bool isLoading = true;
    private TabsEnum activeTab = TabsEnum.ReviewRequests;

    public enum TabsEnum
    {
        ReviewRequests,
        ReviewResponses,
        Friends,
    }

    private ICollection<ReviewRequestDto> reviewRequests = new List<ReviewRequestDto>();
    private ICollection<(ReviewResponseDto response, ReviewRequestDto request)> reviewResponses = new List<(ReviewResponseDto response, ReviewRequestDto request)>();

    private async Task SetActiveTub(TabsEnum tab)
    {
        if (tab == TabsEnum.ReviewRequests)
        {
            reviewRequests = await ReviewRequestService.GetUserReviewRequestAsync(UserId.ToString())
                ?? new List<ReviewRequestDto>();
        }
        else if (tab == TabsEnum.ReviewResponses)
        {
            var responses = await ReviewResponseService.GetUserResponsesAsync(UserId.ToString())
                ?? new List<ReviewResponseDto>();

            var tasks = responses.Select(async res =>
                (res, await ReviewRequestService.GetReviewRequestAsync(res.ReviewRequestId)));

            reviewResponses = (await Task.WhenAll(tasks)).ToList();
        }

        activeTab = tab;
    }


    protected override async Task OnParametersSetAsync()
    {
        await LoadProfile();
        await SetActiveTub(TabsEnum.ReviewRequests);
    }

    private async Task LoadProfile()
    {
        isLoading = true;

        try
        {
            profile = await UserService.GetUserProfileAsync(UserId.ToString());
        }
        catch
        {
            profile = null;
        }

        isLoading = false;
    }

    private string CircleStyle
    {
        get
        {
            if (profile == null || profile.ReviewsGiven <= 0)
                return "background: conic-gradient(#ddd 0deg 360deg);";

            var easyAngle = (int)Math.Round((double)profile.ReviewsEasy / profile.ReviewsGiven * 360);
            var normalAngle = (int)Math.Round((double)profile.ReviewsNormal / profile.ReviewsGiven * 360);
            var hardAngle = 360 - easyAngle - normalAngle;

            var eEnd = easyAngle;
            var nEnd = easyAngle + normalAngle;

            return
                $"background: conic-gradient(" +
                $"#6C63FF 0deg {eEnd}deg, " +
                $"#B9A500 {eEnd}deg {nEnd}deg, " +
                $"#D9534F {nEnd}deg 360deg);";
        }
    }

    private string? GetGitUsername(string url)
    {
        if (string.IsNullOrWhiteSpace(url))
            return null;

        if (Uri.TryCreate(url, UriKind.Absolute, out var uri))
        {
            var segments = uri.AbsolutePath.Trim('/').Split('/');

            if (segments.Length > 0)
                return segments[0];
        }

        return null;
    }

}